#!/bin/bash
# CPUInfo - CPU information and monitoring
# Display CPU details and current usage

set -e

VERBOSE=false

usage() {
    cat << EOF
CPUInfo - CPU Information Tool

USAGE:
    cpuinfo [options]

OPTIONS:
    -v, --verbose         Show detailed info
    -c, --count          Show CPU core count
    -m, --monitor         Real-time monitoring
    -h, --help            Show help

EXAMPLES:
    cpuinfo
    cpuinfo -v
    cpuinfo -m

EOF
}

show_info() {
    echo "🖥️  CPU Information"
    echo "=================="
    echo ""

    # Basic info
    model=$(grep "model name" /proc/cpuinfo | head -1 | cut -d: -f2 | sed 's/^ *//')
    cores=$(grep -c "^processor" /proc/cpuinfo)
    freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq 2>/dev/null || echo "N/A")

    echo "Model: $model"
    echo "Cores: $cores"
    echo "Frequency: $((freq / 1000)) MHz"
    echo ""

    # Usage
    echo "📊 Current Usage:"
    top -bn1 | grep "Cpu(s)" | awk '{print "   User: " $2 ", System: " $4 ", Idle: " $8}'
    echo ""

    # Per-core usage
    echo "📈 Per-Core Usage:"
    mpstat -P ALL 1 1 2>/dev/null | grep -E "CPU|all|Average" | head -10 || echo "   (mpstat not available)"
}

while [[ $# -gt 0 ]]; do
    case $1 in
        -v|--verbose) VERBOSE=true; shift ;;
        -c|--count) grep -c "^processor" /proc/cpuinfo; exit 0 ;;
        -m|--monitor) top; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        *) shift ;;
    esac
done

show_info
EOF